# === Required ===
GEMINI_API_KEY=

# === Security (required in production) ===
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# === Optional ===
PORT=5000
NODE_ENV=development

# MongoDB Atlas (recommended for production on Render; omit to use local file fallback)
# Use database name "smartswap" at the end of the URI. URL-encode special chars in the password.
# MONGODB_URI=<paste-your-atlas-connection-string-here>

# CORS origin when frontend is hosted separately from the API
# FRONTEND_ORIGIN=http://localhost:5173