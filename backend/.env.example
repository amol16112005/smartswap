# SmartSwap Backend Environment Variables
# Copy this file to .env and fill in your values

# === Required for AI Engine ===
GEMINI_API_KEY=
MONGODB_URI=

# === Database (optional) ===
# Leave empty to use local file fallback (history_db.json)
MONGODB_URI=

# === Security (CRITICAL) ===
# Generate a strong random string for production. Used to sign JWT session tokens.
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# === Optional ===
PORT=5000

# Frontend origin for CORS (add your production domain when deployed)
FRONTEND_ORIGIN=http://localhost:5173

# Notes:
# - Never commit your real .env file
# - For local dev you can use the fallback JWT secret, but set a real one before sharing or deploying
# - After changing JWT_SECRET, existing sessions will be invalidated (users simply log in again)
