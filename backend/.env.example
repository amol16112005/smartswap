# === Required ===
GEMINI_API_KEY=

# === Security (required in production) ===
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# === Optional ===
PORT=5000
NODE_ENV=development

# MongoDB Atlas (recommended for production on Render; omit to use local file fallback)
# Paste the connection string from your Atlas dashboard (use database name "smartswap").
# MONGODB_URI=

# CORS origin when frontend is hosted separately from the API
# FRONTEND_ORIGIN=http://localhost:5173